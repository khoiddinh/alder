{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Alder",
  "scopeName": "source.alder",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#boolean" },
    { "include": "#keyword" },
    { "include": "#type" },
    { "include": "#builtin" },
    { "include": "#function-def" },
    { "include": "#operator" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.number-sign.alder",
      "match": "#.*$"
    },
    "string": {
      "name": "string.quoted.double.alder",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.alder",
          "match": "\\\\."
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.float.alder",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.alder",
          "match": "\\b-?[0-9]+\\b"
        }
      ]
    },
    "boolean": {
      "name": "constant.language.boolean.alder",
      "match": "\\b(true|false)\\b"
    },
    "keyword": {
      "patterns": [
        {
          "name": "keyword.control.alder",
          "match": "\\b(if|elif|else|for|while|in|return)\\b"
        },
        {
          "name": "keyword.declaration.alder",
          "match": "\\b(fn|final)\\b"
        },
        {
          "name": "keyword.operator.logical.alder",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "type": {
      "patterns": [
        {
          "name": "storage.type.alder",
          "match": "\\b(int|float|string|bool|void)\\b"
        },
        {
          "name": "storage.type.list.alder",
          "match": "\\blist\\b"
        }
      ]
    },
    "builtin": {
      "name": "support.function.builtin.alder",
      "match": "\\b(print|input|append|pop|len|range|str|int|float|abs|min|max|pow|sqrt|floor|ceil)(?=\\s*\\()"
    },
    "function-def": {
      "patterns": [
        {
          "name": "entity.name.function.alder",
          "match": "(?<=\\bfn\\s)\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "entity.name.function.call.alder",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.alder",
          "match": "->"
        },
        {
          "name": "keyword.operator.comparison.alder",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.bitshift.alder",
          "match": ">>>|<<|>>"
        },
        {
          "name": "keyword.operator.arithmetic.alder",
          "match": "[+\\-*/]"
        },
        {
          "name": "keyword.operator.assignment.alder",
          "match": "="
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.colon.alder",
          "match": ":"
        },
        {
          "name": "punctuation.separator.comma.alder",
          "match": ","
        },
        {
          "name": "punctuation.definition.bracket.alder",
          "match": "[\\[\\]()]"
        }
      ]
    }
  }
}
