fn factorial(n: int) -> int:
	result: int = 1
	i: int = 1
	while i <= n:
			result = result * i
			i = i + 1
	return result

fn sum_list(nums: list[int]) -> int:
	total: int = 0
	for (x: int) in nums:
			total = total + x
	return total

fn main() -> int:
	n: int = 5
	f: int = factorial(n)
	nums: list[int] = [1, 2, 3, 4, 5]
	s: int = sum_list(nums)
	msg: string = ""
	if f > s:
			msg = "factorial wins"
	elif f == s:
			msg = "tie"
	else:
			msg = "sum wins"
	print(msg)
	return 0
